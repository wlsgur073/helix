{
  "description": "Helix memory: inject current-truth at SessionStart; record SessionEnd.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/hooks/session-start.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/hooks/session-end.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
